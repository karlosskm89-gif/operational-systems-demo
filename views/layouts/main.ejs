<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">

  <title><%= typeof title !== "undefined" && title ? title + " | ASR Operational Systems Demo" : "ASR Operational Systems Demo" %></title>
  <meta name="description" content="Public-safe operational systems demo for booking workflows, records, invoices and admin visibility.">
  <meta name="robots" content="index,follow">
  <link rel="canonical" href="<%= canonicalUrl %>">

  <meta property="og:site_name" content="ASR Web Services">
  <meta property="og:title" content="<%= typeof title !== 'undefined' && title ? title + ' | ASR Operational Systems Demo' : 'ASR Operational Systems Demo' %>">
  <meta property="og:description" content="Public-safe operational systems demo for booking workflows, records, invoices and admin visibility.">
  <meta property="og:url" content="<%= canonicalUrl %>">
  <meta property="og:type" content="website">
  <meta property="og:image" content="https://asr-operational-systems-demo.onrender.com/img/operational-demo-hompage-hero-desktop-og.jpg">

  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="<%= typeof title !== 'undefined' && title ? title + ' | ASR Operational Systems Demo' : 'ASR Operational Systems Demo' %>">
  <meta name="twitter:description" content="Public-safe operational systems demo for booking workflows, records, invoices and admin visibility.">
  <meta name="twitter:image" content="https://asr-operational-systems-demo.onrender.com/img/operational-demo-hompage-hero-desktop-og.png">
  <meta name="twitter:creator" content="@asrweb">

  <link rel="icon" href="/favicon.ico" sizes="any">


  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
  <header class="site-header">
    <div class="container header-inner">
      <div class="header-brand">
        <a class="brand-link" href="/">
          <img class="brand-logo" src="/assets/asr_assets/ASR_Logo_Transparent.webp" alt="ASR Web Services logo">
          <span class="brand-text">
            <span class="brand-name">ASR Web Services</span>
            <span class="brand-area">Operational Systems Demo</span>
          </span>
        </a>
      </div>

      <nav class="main-nav" aria-label="Demo navigation">
        <a href="/">Overview</a>
        <a href="/workflow">Workflow</a>
        <a href="/modules">Modules</a>
        <a href="/modules/records">Records</a>
        <a href="/modules/reports">Reports</a>
        <a href="/admin">Admin Demo</a>
        <a href="https://asrweb.ie/portfolio" target="_blank" rel="noopener">Back to ASR Portfolio</a>
      </nav>

      <div class="header-cta">
        <a class="header-button" href="/modules/reports">View reports</a>
      </div>
    </div>
  </header>

  <div class="asr-demo-ribbon" role="note">
    <div class="container asr-demo-ribbon-inner">
      <span>Public-safe ASR proof asset: workflow, records, reports, invoices and export-ready operational thinking.</span>
      <a href="https://asrweb.ie/portfolio" target="_blank" rel="noopener">View ASR portfolio →</a>
    </div>
  </div>

  <main>
    <%- body %>
  </main>

  <footer class="site-footer">
    <div class="footer-strip" aria-hidden="true">
      <img src="/assets/asr_assets/ASR_letter_foot.PNG" alt="" role="presentation" loading="lazy">
    </div>

    <div class="container footer-inner">
      <div class="footer-brand-block">
        <img class="footer-logo" src="/assets/asr_assets/ASR_Logo_Transparent.webp" alt="ASR Web Services logo">
        <div>
          <strong>ASR Web Services</strong>
          <p>Practical websites and operational systems built for real businesses.</p>
        </div>
      </div>

      <div class="footer-links">
        <strong>Demo</strong>
        <a href="/">Overview</a>
        <a href="/workflow">Workflow</a>
        <a href="/modules">Modules</a>
        <a href="/modules/records">Records</a>
        <a href="/modules/reports">Reports</a>
      </div>

      <div class="footer-links">
        <strong>ASR ecosystem</strong>
        <a href="https://asrweb.ie" target="_blank" rel="noopener">Main ASR website</a>
        <a href="https://asrweb.ie/portfolio" target="_blank" rel="noopener">Portfolio</a>
        <a href="https://asr-web-services-starter-kit.onrender.com/" target="_blank" rel="noopener">Starter Kit demo</a>
        <a href="https://asrweb.ie/contact" target="_blank" rel="noopener">Contact ASR</a>
      </div>
    </div>

    <div class="container footer-bottom">
      <p>ASR workflow proof asset • Practical. Maintainable. Purpose-built.</p>
    </div>
  </footer>
</body>
</html>
