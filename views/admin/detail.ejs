<section class="section">
  <div class="container narrow">
    <a href="/admin">← Back to dashboard</a>
    <p class="demo-notice">Public demo admin — this is sample data only. Saving a status demonstrates workflow behaviour; it does not contact anyone or change real records.</p>
    <div class="detail-card">
      <p class="eyebrow">Booking detail</p>
      <h1><%= booking.id %></h1>

      <dl class="details">
        <div><dt>Name</dt><dd><%= booking.name %></dd></div>
        <div><dt>Email</dt><dd><%= booking.email %></dd></div>
        <div><dt>Phone</dt><dd><%= booking.phone || "Not provided" %></dd></div>
        <div><dt>Service</dt><dd><%= booking.service %></dd></div>
        <div><dt>Date/Time</dt><dd><%= booking.date %> at <%= booking.time %></dd></div>
        <div><dt>Status</dt><dd><span class="status"><%= booking.status %></span></dd></div>
      </dl>

      <% if (booking.message) { %>
        <h2>Message</h2>
        <p><%= booking.message %></p>
      <% } %>

      <form method="post" action="/admin/bookings/<%= booking.id %>/status" class="inline-form">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <label>Update status
          <select name="status">
            <% ["New", "Confirmed", "Follow-up", "Closed"].forEach((item) => { %>
              <option value="<%= item %>" <%= booking.status === item ? 'selected' : '' %>><%= item %></option>
            <% }) %>
          </select>
        </label>
        <button class="btn" type="submit">Save sample status</button>
      </form>
    </div>
  </div>
</section>
