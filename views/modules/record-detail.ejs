<section class="section">
  <div class="container narrow">
    <p class="breadcrumb"><a href="/modules/records">← Back to records</a></p>

    <article class="detail-card">
      <p class="eyebrow">Demo record</p>
      <h1><%= record.name %></h1>

      <dl class="detail-list">
        <div><dt>ID</dt><dd><%= record.id %></dd></div>
        <div><dt>Type</dt><dd><%= record.type %></dd></div>
        <div><dt>Owner</dt><dd><%= record.owner %></dd></div>
        <div><dt>Status</dt><dd><%= record.status %></dd></div>
        <div><dt>Last updated</dt><dd><%= record.lastUpdated %></dd></div>
      </dl>

      <h2>Summary</h2>
      <p><%= record.summary %></p>

      <p class="helper-note">
        Demo only. This page shows structure and workflow thinking, not real client data.
      </p>
    </article>
  </div>
</section>
