<section class="section">
  <div class="container narrow">
    <div class="success-card">
      <p class="eyebrow">Request received</p>
      <h1>Thanks, <%= booking.name %>.</h1>
      <p>Your sample booking request has been created as <strong><%= booking.id %></strong>.</p>
      <dl class="details">
        <div><dt>Service</dt><dd><%= booking.service %></dd></div>
        <div><dt>Date</dt><dd><%= booking.date %> at <%= booking.time %></dd></div>
        <div><dt>Status</dt><dd><span class="status"><%= booking.status %></span></dd></div>
      </dl>
      <a class="btn" href="/admin">View in admin demo</a>
    </div>
  </div>
</section>
